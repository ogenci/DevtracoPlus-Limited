{
  "version": 2,
  "nodeVersion": "20.x",
  "buildCommand": "pnpm -r --if-present run build && rm -rf ./public && cp -R artifacts/devtraco-plus/dist/public ./public",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
